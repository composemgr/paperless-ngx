# Paperless-ngx environment configuration
# Copy to app.env and adjust values as needed

# Timezone
TZ=America/New_York

# Host/domain
BASE_HOST_NAME=myhost
BASE_DOMAIN_NAME=example.com

# Admin credentials
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# Application secret (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Database (PostgreSQL)
DB_CREATE_DATABASE_NAME=paperless
DB_USER_NAME=paperless
DB_USER_PASS=changeme_db_password

# Email / SMTP (used for email-to-inbox consumption)
EMAIL_SERVER_HOST=172.17.0.1
EMAIL_SERVER_PORT=587
EMAIL_SERVER_LOGIN_NAME=
EMAIL_SERVER_LOGIN_PASS=
